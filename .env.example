# ─────────────────────────────────────────────
# Meta (Facebook + Instagram) App credentials
# Get these from: https://developers.facebook.com/apps
# ─────────────────────────────────────────────
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# Must match the OAuth redirect URI configured in your Meta app
# For local dev, leave as-is (port 3000)
META_REDIRECT_URI=http://localhost:3000/api/ad-dashboard/auth/callback

# ─────────────────────────────────────────────
# Session cookie secret (for HMAC signing)
# Generate a long random string, e.g.:
#   openssl rand -hex 32
# ─────────────────────────────────────────────
AD_DASHBOARD_SESSION_SECRET=replace_me_with_a_long_random_string

# -------------------------------------------------
# AI Chat (optional)
# Requires Claude Code CLI installed locally.
# No API key needed - uses your Claude Code auth.
# Install: npm install -g @anthropic-ai/claude-code
# -------------------------------------------------
